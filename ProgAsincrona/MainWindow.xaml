<Window x:Class="ProgAsincrona.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow" Height="350" Width="500">
    <Viewbox Stretch="Uniform">
        <Grid Height="350" Width="500">
            <Button x:Name="btnGeneraLettere" Content="Genera lettere casuali" HorizontalAlignment="Left" Margin="46,60,0,0" VerticalAlignment="Top" Height="60" Width="130" Click="btnGeneraLettere_Click"/>
            <Button x:Name="btnStampaLettere" Content="Stampa lettere casuali" HorizontalAlignment="Left" Margin="295,60,0,0" VerticalAlignment="Top" Height="60" Width="130" Click="btnStampaLettere_Click"/>

            <Label x:Name="lblStampaLettere" Content="" HorizontalAlignment="Left" Margin="260,149,0,0" VerticalAlignment="Top" Height="50" Width="200" FontSize="16"/>
            <Label x:Name="lblLettereCasuali" Content="" HorizontalAlignment="Left" Margin="71,149,0,0" VerticalAlignment="Top" Height="50" Width="80" FontSize="16"/>

            <Label Content="Lunghezza parola:" HorizontalAlignment="Left" Margin="185,55,0,0" VerticalAlignment="Top"/>
            <TextBox x:Name="txtLunghezza" HorizontalAlignment="Left" Margin="195,80,0,0" VerticalAlignment="Top" Width="40" Height="25" Text="5" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="14"/>

            <Label Content="Parole create:" HorizontalAlignment="Left" Margin="46,210,0,0" VerticalAlignment="Top" FontSize="14"/>
            <ListBox x:Name="listboxParole" HorizontalAlignment="Left" Margin="46,240,0,0" VerticalAlignment="Top" Height="90" Width="414" FontSize="15"/>
        </Grid>
    </Viewbox>
</Window>